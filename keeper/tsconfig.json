{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "Bundler",
    "esModuleInterop":   true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict":            true,
    "declaration":       true,
    "outDir":            "dist",
    "rootDir":           "src",
    "skipLibCheck":      true,
    "types":             ["node"]
  },
  "include": ["src/**/*.ts"]
}
