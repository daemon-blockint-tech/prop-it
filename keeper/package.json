{
  "name": "tabula-keeper",
  "version": "0.1.0",
  "description": "TabulaMarkets keeper bot — bridges TxLINE feed + TabFM oracle to Solana",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev":              "tsx watch src/index.ts",
    "start":            "tsx src/index.ts",
    "simulate":         "tsx src/simulate.ts",
    "build":            "tsc -p tsconfig.json",
    "lint":             "eslint src --ext .ts"
  },
  "dependencies": {
    "@coral-xyz/anchor":         "^0.30.1",
    "@solana/web3.js":           "^1.95.0",
    "@solana/spl-token":         "^0.4.6",
    "axios":                     "^1.7.0",
    "dotenv":                    "^16.4.5",
    "ws":                        "^8.18.0"
  },
  "devDependencies": {
    "@types/node":               "^20.14.0",
    "@types/ws":                 "^8.5.10",
    "tsx":                       "^4.19.0",
    "typescript":                "^7.0.2"
  }
}
