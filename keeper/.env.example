# --------------------------------------------------------------------
# TabulaMarkets keeper — example environment. Copy to .env and fill in.
# NEVER commit the real .env file — it is git-ignored at the repo root.
# --------------------------------------------------------------------

# Solana cluster to target: localnet | devnet | mainnet-beta
CLUSTER=devnet

# --- RPC + oracle --------------------------------------------------
RPC_URL=https://api.devnet.solana.com
ORACLE_URL=http://127.0.0.1:8787

# --- Wallet --------------------------------------------------------
# Filesystem path to the keeper's Solana keypair. Must be readable ONLY
# by the process user (chmod 600). Consider using KMS/HSM in production.
KEEPER_WALLET=~/.config/solana/id.json

# --- Program IDs ---------------------------------------------------
# Fill in AFTER `anchor deploy`. Do NOT ship the localnet placeholder in prod.
TABULA_PROGRAM_ID=GZ6F2Q5DWQopyxcyTQk7Jko58Fc9jPdEdGdfiSZS7Z9T

# The TxLINE program IDs below are the REAL addresses published by TxODDS.
# Override only if you're pointing at a private fork.
# Devnet:  6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# Mainnet: 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J

# USDC mint — devnet uses a faucet mint, mainnet uses Circle's real USDC.
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- TxLINE REST/SSE ----------------------------------------------
# Defaults come from cfg.ts based on CLUSTER; override only if you must.
# TXLINE_API_BASE=https://txline-dev.txodds.com/api
# TXLINE_GUEST_AUTH=https://txline-dev.txodds.com/auth/guest/start
TXLINE_WALLET_NAME=TabulaKeeper

# --- Runtime knobs -------------------------------------------------
UPDATE_INTERVAL_MS=3000
DIVERGENCE_THRESHOLD=0.02
METRICS_PORT=9464
JSON_LOGS=1
LOG_LEVEL=info

# --- Demo match ----------------------------------------------------
MATCH_ID=world-cup-2026-r16-arg-vs-fra
FINAL_CORNERS_H2=5
